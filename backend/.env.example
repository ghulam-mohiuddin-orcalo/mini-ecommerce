# Copy to .env and adjust as needed. NEVER commit the real .env.

# Database — matches docker-compose.yml defaults
DATABASE_URL="postgresql://shop:shop@localhost:5432/mini_ecommerce?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS / cookies — the frontend origin
FRONTEND_ORIGIN="http://localhost:3000"
