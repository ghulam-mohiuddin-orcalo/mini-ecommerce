# Copy to .env and adjust as needed. NEVER commit the real .env.

# Database — matches docker-compose.yml defaults
DATABASE_URL="postgresql://shop:shop@localhost:5432/mini_ecommerce?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# Max auth attempts (login/signup) per 60s window, per IP
AUTH_THROTTLE_LIMIT=10

# CORS / cookies — the frontend origin
FRONTEND_ORIGIN="http://localhost:3000"

# Stripe Checkout (TEST MODE ONLY — keys must be sk_test_… / whsec_…).
# Secret key: server-side only, NEVER exposed to the browser. Leave blank to keep payments
# disabled (the app still boots; any Checkout call returns 503).
STRIPE_SECRET_KEY=
# Webhook signing secret. From `stripe listen` locally, or the Dashboard endpoint's signing
# secret in test mode. Every incoming webhook signature is verified against this.
STRIPE_WEBHOOK_SECRET=
# Currency for Checkout line items (ISO 4217, lowercase). Defaults to usd.
STRIPE_CURRENCY="usd"
