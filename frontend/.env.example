# Copy to .env.local for local dev.

# Origin of the NestJS backend that /api/* is proxied to (see next.config.ts).
BACKEND_ORIGIN="http://localhost:3001"

# Stripe publishable key (TEST MODE — pk_test_…). Safe to expose to the browser by design.
# The checkout flow redirects to Stripe's hosted Checkout page using the URL the backend
# returns, so this key is not required for the redirect itself; it's provided for any
# client-side Stripe.js usage and to keep the publishable/secret split explicit.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
